# -----------------------------------------------------------------------------
# Environment for Docker Compose / local runs
#
# Setup:  make env     (copies this file to .env and generates SECRET_KEY if needed)
#
# Never commit .env. Add .env to CI secrets instead of storing keys in the repo.
# -----------------------------------------------------------------------------

# Required — Compose will fail if unset or too short. `make env` fills this automatically.
# Manual: openssl rand -base64 64 | tr -d '\n'
SECRET_KEY=

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,web

# --- Reverse proxy (optional Compose profile `reverse-proxy`; see README) ---
# Trust X-Forwarded-Proto / Host from nginx when not hitting Gunicorn directly.
# DJANGO_BEHIND_PROXY=1

# Production HTTPS: list scheme+host+column(port) for every origin that POSTs to Django.
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Prefer HTTP→HTTPS at nginx. Turn on only if Django terminates TLS itself.
# SECURE_SSL_REDIRECT=false

# HSTS (optional). Enable only after HTTPS works end-to-end.
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=true
# SECURE_HSTS_PRELOAD=false

POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce
# Change for anything beyond local dev (see README production checklist).
POSTGRES_PASSWORD=ecommerce

STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional — default is Django console email backend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
